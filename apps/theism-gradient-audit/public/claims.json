    "gradientPosition": 5,
    "specificityWeight": 5,
    "tradition": "Christianity",
    "tags": [
      "prayer",
      "worship",
      "obedience"
    ],
    "dependencyIds": [
      "C032",
      "C034",
      "C046"
    ]
