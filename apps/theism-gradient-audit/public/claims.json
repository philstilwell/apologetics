    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "specificityWeight": 5,
    "tradition": "Christianity",
    "tags": [
      "revelation",
      "Christian God",
      "truth"
    ],
    "dependencyIds": [
      "C028",
      "C034",
      "C040"
    ]
  },
  {
    "id": "C042",
    "text": "Christian scripture reliably conveys core truths that the Christian God wants humans to know.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "specificityWeight": 5,
    "tradition": "Christianity",
    "tags": [
      "scripture",
      "revelation",
      "reliability"
    ],
    "dependencyIds": [
      "C036",
      "C041"
    ]
  },
  {
