    "gradientPosition": 5,
    "specificityWeight": 5,
    "tradition": "Christianity",
    "tags": [
      "Jesus",
      "revelation",
      "authority"
    ],
    "dependencyIds": [
      "C034",
      "C041",
      "C042"
    ]
  },
  {
    "id": "C044",
    "text": "Jesus' resurrection is a substantiable miracle that vindicates Christian claims about God.",
