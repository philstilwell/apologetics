[
  {
    "id": "C1",
    "text": "The physical universe has some explanation beyond merely describing its internal events.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "cosmology",
      "explanation"
    ],
    "dependencyIds": []
  },
  {
    "id": "C2",
    "text": "The universe is not ultimately self-explanatory.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "cosmology",
      "explanation"
    ],
    "dependencyIds": []
  },
  {
    "id": "C3",
    "text": "The universe depends on something that is not identical to the universe.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "dependence",
      "metaphysics"
    ],
    "dependencyIds": []
  },
  {
    "id": "C4",
    "text": "The existence of physical reality is not a brute fact.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "brute-fact",
      "metaphysics"
    ],
    "dependencyIds": []
  },
  {
    "id": "C5",
    "text": "The beginning or finite past of the universe points to a cause beyond ordinary physical events.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "cosmology",
      "causation"
    ],
    "dependencyIds": []
  },
  {
    "id": "C6",
    "text": "The totality of physical reality requires an explanation not contained within that totality.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "totality",
      "explanation"
    ],
    "dependencyIds": []
  },
  {
    "id": "C7",
    "text": "The regularity of nature requires an explanation beyond simply naming physical laws.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "laws",
      "regularity"
    ],
    "dependencyIds": []
  },
  {
    "id": "C8",
    "text": "The initial conditions of the universe were not merely accidental or unexplained.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "initial-conditions",
      "cosmology"
    ],
    "dependencyIds": []
  },
  {
    "id": "C9",
    "text": "The existence of contingent things points to some non-contingent explanatory ground.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "contingency",
      "metaphysics"
    ],
    "dependencyIds": []
  },
  {
    "id": "C10",
    "text": "A minimal creator or source of the universe exists, even if nothing else is known about it.",
    "category": "Minimal Deism",
    "gradientPosition": 1,
    "tags": [
      "creator",
      "source"
    ],
    "dependencyIds": [
      "C1",
      "C3",
      "C6",
      "C9"
    ]
  },
  {
    "id": "C11",
    "text": "The universe was intentionally caused rather than accidentally caused.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "intention",
      "causation"
    ],
    "dependencyIds": [
      "C10"
    ]
  },
  {
    "id": "C12",
    "text": "The universe was caused by something with goal-directed features.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "teleology",
      "causation"
    ],
    "dependencyIds": [
      "C10",
      "C11"
    ]
  },
  {
    "id": "C13",
    "text": "The structure of the universe is better explained by design than by chance, necessity, or unknown impersonal processes.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "design",
      "explanation"
    ],
    "dependencyIds": [
      "C11",
      "C12"
    ]
  },
  {
    "id": "C14",
    "text": "The apparent fine-tuning of physical constants is evidence of purposeful calibration.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "fine-tuning",
      "design"
    ],
    "dependencyIds": [
      "C11",
      "C12",
      "C13"
    ]
  },
  {
    "id": "C15",
    "text": "The universe was created for the emergence of life.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "life",
      "purpose"
    ],
    "dependencyIds": [
      "C11",
      "C12",
      "C14"
    ]
  },
  {
    "id": "C16",
    "text": "The universe was created for the emergence of conscious beings.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "consciousness",
      "purpose"
    ],
    "dependencyIds": [
      "C11",
      "C12",
      "C14",
      "C15"
    ]
  },
  {
    "id": "C17",
    "text": "The creator had some preference for order over chaos.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "order",
      "preference"
    ],
    "dependencyIds": [
      "C10",
      "C11"
    ]
  },
  {
    "id": "C18",
    "text": "The creator had some preference for life-permitting conditions over non-life-permitting conditions.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "life-permitting",
      "preference"
    ],
    "dependencyIds": [
      "C10",
      "C11",
      "C14"
    ]
  },
  {
    "id": "C19",
    "text": "The creator is more like an intelligent agent than an impersonal force.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "agency",
      "intelligence"
    ],
    "dependencyIds": [
      "C11",
      "C12",
      "C17"
    ]
  },
  {
    "id": "C20",
    "text": "The creator intentionally established a stable order that could support meaningful interaction with conscious beings.",
    "category": "Design Deism",
    "gradientPosition": 2,
    "tags": [
      "order",
      "purpose",
      "interaction"
    ],
    "dependencyIds": [
      "C10",
      "C11",
      "C16",
      "C17"
    ]
  },
  {
    "id": "C21",
    "text": "The creator has something analogous to mind, intention, or awareness.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "mind",
      "awareness"
    ],
    "dependencyIds": [
      "C19"
    ]
  },
  {
    "id": "C22",
    "text": "The creator is aware of the universe after creating it.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "awareness",
      "creation"
    ],
    "dependencyIds": [
      "C21"
    ]
  },
  {
    "id": "C23",
    "text": "The creator is aware of conscious creatures within the universe.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "awareness",
      "humans"
    ],
    "dependencyIds": [
      "C21",
      "C22"
    ]
  },
  {
    "id": "C24",
    "text": "The creator is capable of choosing between alternative possible actions.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "choice",
      "agency"
    ],
    "dependencyIds": [
      "C21"
    ]
  },
  {
    "id": "C25",
    "text": "The creator has purposes related to human beings.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "purpose",
      "humans"
    ],
    "dependencyIds": [
      "C21",
      "C23",
      "C24"
    ]
  },
  {
    "id": "C26",
    "text": "The creator cares about whether humans understand reality accurately.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "truth",
      "humans"
    ],
    "dependencyIds": [
      "C23",
      "C25"
    ]
  },
  {
    "id": "C27",
    "text": "The creator can act within the universe after its initial creation.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "intervention-capacity",
      "agency"
    ],
    "dependencyIds": [
      "C21",
      "C24"
    ]
  },
  {
    "id": "C28",
    "text": "The creator can communicate information to human beings.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "communication",
      "revelation-capacity"
    ],
    "dependencyIds": [
      "C21",
      "C23",
      "C26"
    ]
  },
  {
    "id": "C29",
    "text": "The creator can respond differently to different human actions, prayers, or requests.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "response",
      "prayer-capacity"
    ],
    "dependencyIds": [
      "C23",
      "C24",
      "C27"
    ]
  },
  {
    "id": "C30",
    "text": "The creator is not merely the source of the universe but an ongoing personal agent.",
    "category": "Personal Theism",
    "gradientPosition": 3,
    "tags": [
      "personal-theism",
      "agency"
    ],
    "dependencyIds": [
      "C21",
      "C22",
      "C24",
      "C27"
    ]
  },
  {
    "id": "C31",
    "text": "The Christian God actively responds to human persons rather than only sustaining the universe impersonally.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "Christian God",
      "response",
      "personal agency"
    ],
    "dependencyIds": [
      "C27",
      "C29",
      "C30"
    ]
  },
  {
    "id": "C32",
    "text": "The Christian God sometimes answers petitionary prayer in ways not reducible to chance, coincidence, or ordinary causation.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "prayer",
      "answered prayer",
      "causation"
    ],
    "dependencyIds": [
      "C29",
      "C31"
    ]
  },
  {
    "id": "C33",
    "text": "The Christian God sometimes miraculously heals physical or psychological conditions.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "healing",
      "miracle",
      "health"
    ],
    "dependencyIds": [
      "C27",
      "C31",
      "C32"
    ]
  },
  {
    "id": "C34",
    "text": "The Christian God sometimes provides guidance or wisdom that improves human judgment beyond ordinary reflection.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "wisdom",
      "guidance",
      "discernment"
    ],
    "dependencyIds": [
      "C26",
      "C28",
      "C31"
    ]
  },
  {
    "id": "C35",
    "text": "The Christian God sometimes gives people morally corrective conviction or discernment.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "moral guidance",
      "conviction",
      "discernment"
    ],
    "dependencyIds": [
      "C26",
      "C28",
      "C34"
    ]
  },
  {
    "id": "C36",
    "text": "The Christian God sometimes provides foreknowledge, warnings, or prophetic insight about future events.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "foreknowledge",
      "prophecy",
      "future events"
    ],
    "dependencyIds": [
      "C34",
      "C35"
    ]
  },
  {
    "id": "C37",
    "text": "The Christian God sometimes communicates through dreams, impressions, visions, or other experiences without those experiences being merely psychological.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "dreams",
      "visions",
      "religious experience"
    ],
    "dependencyIds": [
      "C28",
      "C34"
    ]
  },
  {
    "id": "C38",
    "text": "The Christian God sometimes protects, delivers, or redirects people through providential events.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "providence",
      "protection",
      "guidance"
    ],
    "dependencyIds": [
      "C25",
      "C27",
      "C31"
    ]
  },
  {
    "id": "C39",
    "text": "The Christian God sometimes brings durable moral or spiritual transformation that exceeds ordinary social or psychological explanation.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "transformation",
      "sanctification",
      "character"
    ],
    "dependencyIds": [
      "C25",
      "C34",
      "C31"
    ]
  },
  {
    "id": "C40",
    "text": "Some Christian claims of divine action can be responsibly distinguished from ordinary coincidence, suggestion, or social reinforcement.",
    "category": "Interventionist Theism",
    "gradientPosition": 4,
    "tags": [
      "evidence",
      "discernment",
      "divine action"
    ],
    "dependencyIds": [
      "C26",
      "C31",
      "C32",
      "C33",
      "C36"
    ]
  },
  {
    "id": "C41",
    "text": "The Christian God reveals truth about himself to humans rather than leaving humans to infer everything from nature alone.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "revelation",
      "Christian God",
      "truth"
    ],
    "dependencyIds": [
      "C28",
      "C34",
      "C40"
    ]
  },
  {
    "id": "C42",
    "text": "Christian scripture reliably conveys core truths that the Christian God wants humans to know.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "scripture",
      "revelation",
      "reliability"
    ],
    "dependencyIds": [
      "C36",
      "C41"
    ]
  },
  {
    "id": "C43",
    "text": "Jesus is the central and uniquely authoritative revelation of the Christian God's character and purposes.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "Jesus",
      "revelation",
      "authority"
    ],
    "dependencyIds": [
      "C34",
      "C41",
      "C42"
    ]
  },
  {
    "id": "C44",
    "text": "Jesus' resurrection is a substantiable miracle that vindicates Christian claims about God.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "Jesus",
      "resurrection",
      "miracle"
    ],
    "dependencyIds": [
      "C31",
      "C32",
      "C40",
      "C43"
    ]
  },
  {
    "id": "C45",
    "text": "The Christian God forgives sins and reconciles humans to himself through Jesus Christ.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "forgiveness",
      "reconciliation",
      "Jesus"
    ],
    "dependencyIds": [
      "C25",
      "C41",
      "C44"
    ]
  },
  {
    "id": "C46",
    "text": "The Holy Spirit is an active divine agent who guides, teaches, empowers, and comforts believers.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "Holy Spirit",
      "guidance",
      "empowerment"
    ],
    "dependencyIds": [
      "C30",
      "C34",
      "C41"
    ]
  },
  {
    "id": "C47",
    "text": "The Christian God can give spiritual gifts such as prophecy, healing, wisdom, discernment, or tongues.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "spiritual gifts",
      "prophecy",
      "healing",
      "wisdom"
    ],
    "dependencyIds": [
      "C32",
      "C33",
      "C34",
      "C36",
      "C46"
    ]
  },
  {
    "id": "C48",
    "text": "Christian prayer, worship, and obedience can become real channels of interaction with God rather than only human ritual.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "prayer",
      "worship",
      "obedience"
    ],
    "dependencyIds": [
      "C32",
      "C34",
      "C46"
    ]
  },
  {
    "id": "C49",
    "text": "The Christian God can guide communities as well as individuals toward truth, repentance, and moral correction.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "community",
      "truth",
      "repentance"
    ],
    "dependencyIds": [
      "C34",
      "C40",
      "C46",
      "C48"
    ]
  },
  {
    "id": "C50",
    "text": "The core Christian picture is true: God personally acts through Christ and the Spirit to save, guide, heal, and transform human beings.",
    "category": "Specific Christian Theism",
    "gradientPosition": 5,
    "tags": [
      "Jesus",
      "Holy Spirit",
      "salvation",
      "healing",
      "transformation"
    ],
    "dependencyIds": [
      "C43",
      "C44",
      "C45",
      "C46",
      "C47",
      "C49"
    ]
  }
]
