    "gradientPosition": 5,
    "specificityWeight": 5,
    "tradition": "Christianity",
    "tags": [
      "Jesus",
      "resurrection",
      "miracle"
    ],
    "dependencyIds": [
      "C031",
      "C032",
      "C040",
      "C043"
    ]
  },
  {
